{
  "info": {
    "name": "Pathfinder Functional Backend API",
    "description": "This is the complete API collection for the Pathfinder Functional Backend project. It includes endpoints for Maps, Obstacles, Waypoints, Route calculation, and Users.\n\n### Usage\n1. Import this collection and the associated `pathfinder-local.postman_environment.json` into Postman.\n2. Ensure the **Pathfinder Local** environment is selected in the top right corner.\n3. Run the **Health Check** first to verify connectivity.\n\n*Note: Route distance is currently computed via a Manhattan distance placeholder pending Phase 5B algorithm implementation.*\n\nDate generated: **2026-07-22**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
